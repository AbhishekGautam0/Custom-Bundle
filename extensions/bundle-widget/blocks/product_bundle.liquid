<div
  id="bundle-block"
  class="bundle-widget"
  data-main-product-id="{{ product.selected_or_first_available_variant.id }}"
  data-api-base-url="{{ block.settings.api_base_url }}"
  data-shop="{{ shop.permanent_domain }}"
>
  <div class="bundle-widget__header">
    <h3 class="bundle-widget__title">Bundle & Save</h3>
    <p class="bundle-widget__subtitle">Choose extra products to add with this item.</p>
  </div>
  <div id="bundle-products-container" class="bundle-widget__products">
    Loading bundle...
  </div>
  <button type="button" id="bundle-add-to-cart" class="bundle-widget__button">
    Add bundle to cart
  </button>
</div>

<style>
  .bundle-widget {
    border: 1px solid rgba(18, 18, 18, 0.12);
    border-radius: 12px;
    padding: 16px;
    margin: 16px 0;
    background: #fff;
  }
  .bundle-widget__title {
    margin: 0;
    font-size: 20px;
    line-height: 1.2;
  }
  .bundle-widget__subtitle {
    margin: 6px 0 0;
    color: rgba(18, 18, 18, 0.72);
    font-size: 14px;
  }
  .bundle-widget__products {
    margin-top: 14px;
    display: grid;
    gap: 10px;
  }
  .bundle-widget__row {
    display: grid;
    grid-template-columns: auto 64px 1fr;
    gap: 12px;
    align-items: center;
    border: 1px solid rgba(18, 18, 18, 0.1);
    border-radius: 10px;
    padding: 10px;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }
  .bundle-widget__row:hover {
    border-color: rgba(18, 18, 18, 0.25);
    box-shadow: 0 4px 18px rgba(18, 18, 18, 0.08);
  }
  .bundle-widget__checkbox {
    width: 18px;
    height: 18px;
  }
  .bundle-widget__image {
    width: 64px;
    height: 64px;
    border-radius: 8px;
    object-fit: cover;
    background: #f3f3f3;
  }
  .bundle-widget__name {
    font-size: 15px;
    font-weight: 600;
    line-height: 1.3;
    margin: 0;
  }
  .bundle-widget__variant {
    margin-top: 4px;
    font-size: 13px;
    color: rgba(18, 18, 18, 0.65);
  }
  .bundle-widget__price {
    margin-top: 4px;
    font-size: 14px;
    font-weight: 600;
  }
  .bundle-widget__button {
    margin-top: 14px;
    width: 100%;
    border: 0;
    border-radius: 10px;
    background: #121212;
    color: #fff;
    padding: 12px 16px;
    cursor: pointer;
    font-size: 14px;
    font-weight: 600;
  }
  .bundle-widget__button:hover {
    opacity: 0.92;
  }
  .bundle-widget__button[disabled] {
    opacity: 0.5;
    cursor: not-allowed;
  }
</style>

{{ 'bundle.js' | asset_url | script_tag }}

{% schema %}
{
  "name": "Product bundle",
  "target": "section",
  "templates": ["product"],
  "settings": [
    {
      "type": "text",
      "id": "api_base_url",
      "label": "App API base URL",
      "default": "https://example.com"
    }
  ]
}
{% endschema %}

